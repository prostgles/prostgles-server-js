{
  "name": "server_tests",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "start": "tsc-watch --onSuccess \"node dist/server/index.js\"",
    "dev": "NOSTOP=true npm start",
    "build": "rm -rf ./node_modules/* && rm -rf ./media/* && rm -rf ./dist/* && npm i && tsc",
    "test-server": "TEST_TYPE=server node --inspect-brk --trace-uncaught --test dist/server/index.js ",
    "test-client": "TEST_TYPE=client node --trace-uncaught --test dist/server/index.js "
  },
  "dependencies": {
    "express": "^5.2.1",
    "prostgles-server": "file:../.."
  },
  "devDependencies": {
    "@types/node": "^20.19.37",
    "socket.io": "^4.8.3",
    "tsc-watch": "^6.3.1",
    "typescript": "^5.9.3"
  }
}
